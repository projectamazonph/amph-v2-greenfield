# Next.js's standalone output tracer (@vercel/nft under Turbopack) resolves
# "external" runtime requires against a real node_modules tree. pnpm's
# default nested/symlinked store layout hides transitive-only packages
# (@swc/helpers, @next/env, .prisma/client, @react-pdf/primitives,
# @phc/format, ...) several directories deep, and the tracer misses them —
# each one crashes `node .next/standalone/server.js` with MODULE_NOT_FOUND
# at request time. A hoisted, flat node_modules avoids the whole class of
# bug (this is the standard pnpm + Next.js standalone workaround).
node-linker=hoisted
